# ── SENTINEL-GRC Environment Configuration ──────────────────────────────────
# Copy this file to .env and update values for your environment

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="SENTINEL-GRC"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_super_secret_jwt_key_sentinel_grc_2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_secret@db:5432/sentinel_grc
SYNC_DATABASE_URL=postgresql://sentinel:sentinel_secret@db:5432/sentinel_grc

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── MinIO Evidence Store ─────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=sentinel_minio
MINIO_SECRET_KEY=sentinel_minio_secret
MINIO_BUCKET=evidence-vault
MINIO_SECURE=false

# ─── First Superuser (CISO) ───────────────────────────────────────────────────
FIRST_SUPERUSER_EMAIL=admin@sentinel.local
FIRST_SUPERUSER_PASSWORD=SentinelDemo2024
FIRST_SUPERUSER_NAME="Admin Shreyas"

# ─── Threat Intelligence APIs (Free — get keys at these URLs) ─────────────────
# NVD API Key: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here
# No key needed for MITRE ATT&CK — public API
MITRE_ATTACK_API=https://attack.mitre.org/
# CISA KEV Feed (no key needed)
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json

# ─── Control Runner Schedule ──────────────────────────────────────────────────
# How often to run full control sweep (seconds). Default: 6 hours
CONTROL_SWEEP_INTERVAL=21600
# Alert threshold for risk (in thousands GBP)
RISK_ALERT_THRESHOLD_GBP=50000

# ─── Report Settings ──────────────────────────────────────────────────────────
ORG_NAME="Sentinel GRC Platform"
ORG_LOGO_PATH=/app/static/logo.png
REPORT_OUTPUT_DIR=/app/reports

# ─── HMAC Evidence Signing Key ────────────────────────────────────────────────
EVIDENCE_HMAC_KEY=CHANGE_THIS_evidence_signing_key_32_chars_min
